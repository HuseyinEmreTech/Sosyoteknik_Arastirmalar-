---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Yeni Yazı - Admin">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div id="yeni-yazi-root">
      <p class="text-[var(--color-text-muted)]">Yükleniyor...</p>
    </div>
  </div>
</Layout>

<script>
  (async () => {
    const res = await fetch("/api/auth/me", { credentials: "include" });
    const { user } = await res.json();
    if (!user || (user.role !== "admin" && user.role !== "super_admin")) {
      window.location.href = "/admin/login";
      return;
    }

    const root = document.getElementById("yeni-yazi-root");
    if (!root) return;

    root.innerHTML = `
      <h1 class="text-2xl font-bold text-[var(--color-text)] mb-6">Yeni Yazı</h1>
      <form id="yazi-form" class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-[var(--color-text)] mb-2">Başlık</label>
          <input type="text" name="title" required class="w-full px-4 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)]" placeholder="Yazı başlığı" />
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--color-text)] mb-2">Özet (isteğe bağlı)</label>
          <textarea name="excerpt" rows="2" class="w-full px-4 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)]" placeholder="Kısa özet"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--color-text)] mb-2">Kapak görseli URL (isteğe bağlı)</label>
          <input type="url" name="coverImageUrl" class="w-full px-4 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)]" placeholder="https://..." />
        </div>
        <div>
          <label class="block text-sm font-medium text-[var(--color-text)] mb-2">İçerik (Markdown)</label>
          <textarea name="bodyMd" required rows="15" class="w-full px-4 py-2 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg)] text-[var(--color-text)] font-mono text-sm" placeholder="# Başlık\n\nParagraf..."></textarea>
        </div>
        <div class="flex items-center gap-4">
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="published" />
            <span class="text-[var(--color-text)]">Yayınla</span>
          </label>
        </div>
        <div id="form-error" class="text-red-500 text-sm hidden"></div>
        <div class="flex gap-4">
          <button type="submit" class="px-6 py-2 rounded-lg bg-[var(--color-accent)] text-white hover:opacity-90">Kaydet</button>
          <a href="/admin/yazilar" class="px-6 py-2 rounded-lg border border-[var(--color-border)] text-[var(--color-text)]">İptal</a>
        </div>
      </form>
    `;

    const form = document.getElementById("yazi-form") as HTMLFormElement;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const data = {
        title: fd.get("title"),
        excerpt: fd.get("excerpt") || "",
        coverImageUrl: fd.get("coverImageUrl") || "",
        bodyMd: fd.get("bodyMd"),
        published: (form.querySelector("[name=published]") as HTMLInputElement).checked,
      };

      const errEl = document.getElementById("form-error");
      if (errEl) { errEl.classList.add("hidden"); errEl.textContent = ""; }

      const r = await fetch("/api/posts", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
        credentials: "include",
      });

      const json = await r.json();
      if (!r.ok) {
        if (errEl) { errEl.textContent = json.error || "Hata"; errEl.classList.remove("hidden"); }
        return;
      }
      window.location.href = "/admin/yazilar";
    });
  })();
</script>
