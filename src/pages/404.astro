---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Sayfa Bulunamadı - Sosyoteknik Araştırmalar">
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <h1 class="text-4xl font-bold text-[var(--color-text)] mb-4">404</h1>
    <p class="text-lg text-[var(--color-text-muted)] mb-8">Aradığınız sayfa bulunamadı.</p>
    <a href="/" class="inline-flex items-center px-6 py-3 rounded-lg bg-[var(--color-accent)] text-white hover:opacity-90 transition-opacity">
      Ana Sayfaya Dön
    </a>
  </div>
</Layout>
