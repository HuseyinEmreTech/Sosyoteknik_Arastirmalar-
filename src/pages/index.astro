---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Sosyoteknik Araştırmalar" description="Blog ve araştırma platformu">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <section class="text-center py-16">
      <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-4">
        Sosyoteknik Araştırmalar
      </h1>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        Hoş geldiniz. Bu platformda blog yazılarımızı ve araştırmalarımızı paylaşıyoruz.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/blog"
          class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium bg-[var(--color-accent)] text-white hover:opacity-90 transition-opacity"
        >
          Bloğa Git
        </a>
        <a
          href="/admin"
          class="inline-flex items-center justify-center px-6 py-3 rounded-lg font-medium border border-[var(--color-border)] text-[var(--color-text)] hover:bg-[var(--color-surface)] transition-colors"
        >
          Admin Girişi
        </a>
      </div>
    </section>
  </div>
</Layout>
